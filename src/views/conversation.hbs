<div class="mx-auto max-w-7xl px-5 py-8 sm:px-8 sm:py-12"><div class="mb-7 flex items-start gap-4"><a href="/" class="mt-1 grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-white text-muted shadow-sm transition hover:text-primary"><i data-lucide="arrow-left" class="h-5 w-5"></i></a><div><p class="eyebrow mb-1">Live workspace</p><h1 class="font-display text-2xl font-extrabold sm:text-3xl">Real-time conversation</h1></div></div>
<div class="mb-5 rounded-2xl border px-4 py-3 text-sm {{#if database.connected}}border-emerald-100 bg-emerald-50 text-emerald-700{{else}}border-amber-100 bg-amber-50 text-amber-700{{/if}}"><strong>Database:</strong> {{database.message}} <span class="ml-1 font-semibold">AI processing is currently a clearly labeled demo mock.</span></div>
<section class="card mb-5 flex flex-col gap-4 p-4 sm:flex-row sm:items-end sm:p-5"><div class="flex flex-1 gap-3">{{> language-select id="source-language" label="Source language" options=sourceLanguages}}{{> language-select id="target-language" label="Target language" options=targetLanguages}}</div><div class="sm:ml-auto"><span class="mb-1.5 block text-xs font-semibold text-muted">Recording status</span><span id="recording-status" class="flex h-[42px] items-center gap-2 rounded-xl bg-[#f2f3f7] px-4 text-sm font-bold text-muted"><i data-lucide="circle" class="h-2.5 w-2.5 fill-current"></i><span>Idle</span></span></div></section>
<div class="grid gap-5 lg:grid-cols-2">{{> transcript-panel kind="original" title="Original transcript" subtitle="Language detected automatically" emptyText="Your transcript will appear here as you speak"}}{{> transcript-panel kind="translated" translated=true title="Translated text" subtitle="Translated to Vietnamese" emptyText="Translations will appear here in real time"}}</div><div class="mt-5">{{> recorder-controls}}</div><div id="recorder-error" role="alert" class="mt-4 hidden rounded-2xl border border-red-100 bg-red-50 p-4 text-sm text-red-700"></div><div class="mt-5">{{> summary-result}}</div></div>
