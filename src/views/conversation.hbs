<div class="mx-auto max-w-7xl px-5 py-8 sm:px-8 sm:py-12"><div class="mb-7 flex items-start gap-4"><a href="/" class="mt-1 grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-white text-muted shadow-sm transition hover:text-primary"><i data-lucide="arrow-left" class="h-5 w-5"></i></a><div><p class="eyebrow mb-1">Live workspace</p><h1 class="font-display text-2xl font-extrabold sm:text-3xl">Real-time conversation</h1></div></div>
<div class="mb-5 rounded-2xl border px-4 py-3 text-sm {{#if database.connected}}border-emerald-100 bg-emerald-50 text-emerald-700{{else}}border-amber-100 bg-amber-50 text-amber-700{{/if}}"><strong>Database:</strong> {{database.message}} <span class="ml-1 font-semibold">AI processing is currently a clearly labeled demo mock.</span></div>
<section class="card mb-5 flex flex-col gap-3 p-4 lg:flex-row lg:items-end">
  <div class="grid min-w-0 flex-1 grid-cols-1 gap-2.5 sm:grid-cols-3">
    {{> language-select id="source-language" label="Source" options=sourceLanguages}}
    {{> language-select id="target-language" label="Target" options=targetLanguages}}
    <label class="min-w-0"><span class="mb-1.5 block text-xs font-semibold text-muted">Speech-to-Text model</span><span class="relative block"><select id="speech-model" class="w-full appearance-none rounded-xl border border-[#e5e6ee] bg-white py-2.5 pl-3 pr-9 text-sm font-semibold outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10">{{#each speechModels}}<option value="{{id}}" data-name="{{name}}" data-rtf="{{metrics.rtf}}" data-wer="{{metrics.wer}}" data-bleu="{{metrics.bleu}}">{{label}}</option>{{/each}}</select><i data-lucide="cpu" class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted"></i></span></label>
  </div>
  <div class="lg:ml-1 lg:w-36"><span class="mb-1.5 block text-xs font-semibold text-muted">Status</span><span id="recording-status" class="flex h-[42px] items-center gap-2 rounded-xl bg-[#f2f3f7] px-4 text-sm font-bold text-muted"><i data-lucide="circle" class="h-2.5 w-2.5 fill-current"></i><span>Idle</span></span></div>
</section>
<div class="grid items-stretch gap-5 lg:grid-cols-2">
  {{> transcript-panel kind="original" title="Original transcript" subtitle="Language detected automatically" emptyText="Your transcript will appear here as you speak"}}
  {{> transcript-panel kind="translated" translated=true title="Translated text" subtitle="Translated to Vietnamese" emptyText="Translations will appear here in real time"}}
</div>
<div id="post-recording-layout" class="mt-5 grid items-stretch gap-5 transition-all duration-500">
  <div id="recorder-column" class="min-w-0">{{> recorder-controls}}</div>
  <section id="evaluation-section" class="card hidden min-w-0 overflow-hidden" aria-labelledby="evaluation-title">
    <div class="flex items-center justify-between gap-4 border-b border-[#eff0f5] px-5 py-4 sm:px-6"><div><p class="eyebrow mb-1">Performance report</p><h2 id="evaluation-title" class="font-display font-bold">Model evaluation</h2><p class="mt-0.5 text-xs text-muted">Mock benchmark · <span id="metric-model-name">Selected model</span></p></div><span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-emerald-50 text-emerald-600"><i data-lucide="gauge" class="h-5 w-5"></i></span></div>
    <div class="overflow-x-auto"><table class="w-full min-w-[480px] text-left"><thead class="bg-[#fafafe] text-[11px] font-bold uppercase tracking-wider text-muted"><tr><th class="px-5 py-3">Metric</th><th class="px-4 py-3">Result</th><th class="px-5 py-3">Evaluation target</th></tr></thead><tbody class="divide-y divide-[#eff0f5] text-sm">
      <tr><td class="px-5 py-3.5"><span class="font-display font-extrabold text-primary">RTF</span><span class="ml-2 text-xs text-muted">Lower is better</span></td><td id="metric-rtf" class="px-4 py-3.5 font-bold tabular-nums">—</td><td class="px-5 py-3.5 text-muted">System latency</td></tr>
      <tr><td class="px-5 py-3.5"><span class="font-display font-extrabold text-primary">WER</span><span class="ml-2 text-xs text-muted">Lower is better</span></td><td id="metric-wer" class="px-4 py-3.5 font-bold tabular-nums">—</td><td class="px-5 py-3.5 text-muted">Speech-to-Text accuracy</td></tr>
      <tr><td class="px-5 py-3.5"><span class="font-display font-extrabold text-primary">BLEU</span><span class="ml-2 text-xs text-muted">Higher is better</span></td><td id="metric-bleu" class="px-4 py-3.5 font-bold tabular-nums">—</td><td class="px-5 py-3.5 text-muted">Translation quality</td></tr>
    </tbody></table></div>
  </section>
</div><div id="recorder-error" role="alert" class="mt-4 hidden rounded-2xl border border-red-100 bg-red-50 p-4 text-sm text-red-700"></div><div class="mt-5">{{> summary-result}}</div></div>
