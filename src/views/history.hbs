<div class="mx-auto max-w-7xl px-5 py-12 sm:px-8 sm:py-16"><div class="mb-9 flex flex-col justify-between gap-5 sm:flex-row sm:items-end"><div><p class="eyebrow mb-2">Your library</p><h1 class="font-display text-3xl font-extrabold sm:text-4xl">Conversation history</h1><p class="mt-2 text-muted">Revisit translations, summaries, and decisions from past conversations.</p></div><a href="/conversation" class="btn-primary"><i data-lucide="plus" class="h-[18px] w-[18px]"></i>New conversation</a></div><div id="database-banner" class="mb-5 rounded-2xl border px-4 py-3 text-sm {{#if database.connected}}border-emerald-100 bg-emerald-50 text-emerald-700{{else}}border-amber-100 bg-amber-50 text-amber-700{{/if}}">{{database.message}}</div><div id="history-loading" class="card grid min-h-52 place-items-center p-8 text-center"><div><i data-lucide="loader-circle" class="mx-auto mb-3 h-8 w-8 animate-spin text-primary"></i><p class="text-sm text-muted">Loading conversations…</p></div></div><div id="history-error" class="card hidden min-h-52 place-items-center p-8 text-center"></div><div id="history-list" class="hidden gap-4"></div><div id="history-empty" class="card hidden min-h-72 place-items-center p-8 text-center"><div><i data-lucide="message-square-text" class="mx-auto mb-4 h-9 w-9 text-primary"></i><h2 class="font-display text-xl font-bold">No conversations yet</h2><p class="mt-2 text-sm text-muted">Your saved conversations will show up here.</p></div></div></div>
