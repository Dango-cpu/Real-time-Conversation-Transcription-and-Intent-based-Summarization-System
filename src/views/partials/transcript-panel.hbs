<section class="card flex min-h-[390px] flex-col overflow-hidden" data-panel="{{kind}}">
  <div class="flex items-center gap-3 border-b border-[#eff0f5] px-5 py-4 sm:px-6"><span class="grid h-10 w-10 place-items-center rounded-xl {{#if translated}}bg-cyan/10 text-cyan{{else}}bg-primary/10 text-primary{{/if}}"><i data-lucide="{{#if translated}}languages{{else}}message-square-text{{/if}}" class="h-5 w-5"></i></span><div><h2 class="font-display font-bold">{{title}}</h2><p class="panel-subtitle text-xs text-muted">{{subtitle}}</p></div></div>
  <div class="panel-messages flex-1 space-y-4 p-5 sm:p-6"><div class="panel-empty grid h-full min-h-[260px] place-items-center text-center"><div><i data-lucide="{{#if translated}}languages{{else}}message-square-text{{/if}}" class="mx-auto mb-3 h-8 w-8 text-[#c9cbd7]"></i><p class="text-sm text-muted">{{emptyText}}</p></div></div></div>
</section>
