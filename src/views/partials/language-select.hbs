<label class="min-w-0 flex-1"><span class="mb-1.5 block text-xs font-semibold text-muted">{{label}}</span><span class="relative block"><select id="{{id}}" class="w-full appearance-none rounded-xl border border-[#e5e6ee] bg-white py-2.5 pl-3 pr-9 text-sm font-semibold outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10">{{#each options}}<option>{{this}}</option>{{/each}}</select><i data-lucide="chevron-down" class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted"></i></span></label>
