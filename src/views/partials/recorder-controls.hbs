<section id="recorder-card" class="card relative h-full overflow-hidden p-5 transition-all duration-500 sm:p-6"><div class="absolute inset-y-0 left-0 w-1 bg-gradient-to-b from-primary to-cyan"></div><div class="flex h-full flex-col items-center gap-5 lg:flex-row">
  <div class="flex items-center gap-4 lg:w-52"><span class="relative grid h-12 w-12 place-items-center rounded-full bg-primary/10 text-primary"><span id="pulse-ring" class="absolute inset-0 hidden rounded-full bg-primary/25"></span><i data-lucide="mic" class="relative h-5 w-5"></i></span><div><p class="text-xs font-semibold text-muted">Recording time</p><p id="elapsed" class="font-display text-2xl font-bold tabular-nums">00:00</p></div></div>
  <div id="waveform" class="flex h-12 min-w-0 flex-1 items-center justify-center gap-1" aria-label="Audio waveform"></div>
  <div id="recorder-actions" class="flex w-full flex-wrap justify-center gap-2 lg:w-auto"><button id="start-button" class="btn-primary flex-1 px-4 py-3 sm:flex-none"><i data-lucide="mic" class="h-[18px] w-[18px]"></i><span>Start recording</span></button><button id="pause-button" disabled class="btn-secondary flex-1 px-4 py-3 sm:flex-none"><i data-lucide="circle-pause" class="h-[18px] w-[18px]"></i>Pause</button><button id="stop-button" disabled class="btn-secondary flex-1 border-red-100 px-4 py-3 text-red-500 sm:flex-none"><i data-lucide="square" class="h-4 w-4 fill-current"></i>Stop & save</button></div>
  <div id="recording-complete" class="hidden shrink-0 items-center gap-2 rounded-xl bg-emerald-50 px-4 py-3 text-sm font-bold text-emerald-600"><i data-lucide="circle-check" class="h-[18px] w-[18px]"></i>Recording saved</div>
</div></section>
